generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USER + SUBTYPE PROFILES
// Table-per-subtype: User holds shared auth/contact fields, each role has its
// own profile table with a 1:1 relation back to User via a shared PK/FK.
// ---------------------------------------------------------------------------

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(100) // bcrypt/argon2 hash, never plaintext
  firstName String   @map("first_name") @db.VarChar(50)
  lastName  String   @map("last_name") @db.VarChar(50)
  phone     String?  @db.VarChar(20)
  wilaya    String?  @db.VarChar(50)
  address   String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  adminProfile    AdminProfile?
  clientProfile   ClientProfile?
  providerProfile ProviderProfile?

  @@map("user")
}

model AdminProfile {
  adminId     Int     @id @map("admin_id")
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  user User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_profile")
}

model ClientProfile {
  clientId    Int     @id @map("client_id")
  preferences String? @db.VarChar(100)

  user   User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  events Event[]

  @@map("client_profile")
}

model ProviderProfile {
  providerId      Int      @id @map("provider_id")
  serviceCategory String?  @map("service_category") @db.VarChar(100)
  experience      String?  @db.VarChar(500)
  certification   String?  @db.VarChar(500)
  studyDegree     String?  @map("study_degree") @db.VarChar(100)
  profilePic      String?  @map("profile_pic") @db.VarChar(200)
  about           String?  @db.VarChar(500)
  isAvailable     Boolean  @default(true) @map("is_available")

  user       User        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  services   Service[]
  portfolios Portfolio[]

  @@map("provider_profile")
}

// ---------------------------------------------------------------------------
// SERVICES + PORTFOLIO
// ---------------------------------------------------------------------------

model Service {
  id          Int      @id @default(autoincrement())
  providerId  Int      @map("provider_id")
  serviceName String   @map("service_name") @db.VarChar(100)
  description String?  @db.VarChar(500)
  category    String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [providerId], onDelete: Cascade)
  bookings Booking[]

  @@map("service")
}

model Portfolio {
  id          Int      @id @default(autoincrement())
  providerId  Int      @map("provider_id")
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  provider ProviderProfile  @relation(fields: [providerId], references: [providerId], onDelete: Cascade)
  images   PortfolioImage[]

  @@map("portfolio")
}

model PortfolioImage {
  id          Int      @id @default(autoincrement())
  portfolioId Int      @map("portfolio_id")
  imagePath   String   @map("image_path") @db.VarChar(300)
  createdAt   DateTime @default(now()) @map("created_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_image")
}

// ---------------------------------------------------------------------------
// EVENTS + BOOKINGS
// ---------------------------------------------------------------------------

model Event {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  title     String   @db.VarChar(100)
  date      DateTime @db.Date
  location  String   @db.VarChar(100)

  client   ClientProfile @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  bookings Booking[]

  @@map("event")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}


model Booking {
  id                    Int      @id @default(autoincrement())
  eventId               Int      @map("event_id")
  serviceId             Int      @map("service_id") // derive provider via service.providerId
  bookingDate           DateTime @map("booking_date") @db.Date
  startTime             DateTime @map("start_time") @db.Time
  endTime               DateTime @map("end_time") @db.Time
  status                BookingStatus @default(PENDING)
  paymentAmount         Float?   @map("payment_amount")
  paymentFeePercentage  Float?   @map("payment_fee_percentage")
  paymentStatus         PaymentStatus @default(UNPAID) @map("payment_status")
  createdAt             DateTime @default(now()) @map("created_at")

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@map("booking")
}
